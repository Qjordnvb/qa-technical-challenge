{
  "name": "qa-technical-challenge",
  "version": "1.0.0",
  "description": "Working repository for a live QA automation technical challenge (UI E2E, API, and code exercises) — TypeScript.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/specs",
    "test:regression": "playwright test tests/specs --grep-invert @known-defect",
    "test:defects": "playwright test tests/specs --grep @known-defect",
    "test:personas": "playwright test tests/specs/personas.spec.ts",
    "test:a11y": "playwright test tests/specs/accessibility.spec.ts",
    "test:api": "playwright test tests/api.spec.ts",
    "test:api-suite": "playwright test --config=playwright.api.config.ts",
    "report:api": "playwright show-report playwright-report-api --port 9324",
    "test:unit": "playwright test tests/solution.spec.ts",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report"
  },
  "keywords": [
    "qa",
    "automation",
    "playwright",
    "typescript",
    "e2e",
    "api-testing"
  ],
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
