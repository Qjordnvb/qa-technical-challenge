{
  "name": "qa-technical-challenge",
  "version": "1.0.0",
  "description": "Working repository for a live QA automation technical challenge (UI E2E, API, and code exercises) — TypeScript.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/example.e2e.spec.ts",
    "test:api": "playwright test tests/api.spec.ts",
    "test:unit": "playwright test tests/solution.spec.ts",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report"
  },
  "keywords": ["qa", "automation", "playwright", "typescript", "e2e", "api-testing"],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
